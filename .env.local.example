# Copy this file to .env.local and fill in your values.
# HealthIntel runs entirely on local mock data — no API keys are required to run it.

# Public base URL of the deployment (used for SEO / OpenGraph metadata)
NEXT_PUBLIC_SITE_URL=https://healthintel.visioninaction.cm

# Optional: Mapbox GL token if you later swap the OpenStreetMap/Leaflet map
# NEXT_PUBLIC_MAPBOX_TOKEN=pk.eyJ1...
